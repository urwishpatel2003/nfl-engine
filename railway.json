{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS"
  },
  "deploy": {
    "startCommand": "python dashboard/seed.py && gunicorn dashboard.server:app --bind 0.0.0.0:$PORT --workers 1 --threads 4 --timeout 120",
    "healthcheckPath": "/api/team_meta",
    "healthcheckTimeout": 180,
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 3
  }
}
